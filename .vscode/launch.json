{
	"version": "0.2.0",
	"configurations": [
		{
			"type": "java",
			"name": "Launch Current File",
			"request": "launch",
			"mainClass": "${file}"
		},
		{
			"type": "java",
			"name": "Local Dynamo Tests",
			"request": "launch",
			"mainClass": "org.monstercubedraft.Main",
			"projectName": "local-dynamo-tests",
			"args": [
				"--profile",
				"${input:awsProfileName}"
			]
		},
		{
			"type": "node",
			"request": "launch",
			"name": "Debug Lambda handler",
			"runtimeExecutable": "tsx",
			"program": "${workspaceFolder}/resources/handlers/local-runner.ts",
			"args": [
				"${input:handlerName}"
			],
			"cwd": "${workspaceFolder}/resources"
		},
		{
			"type": "node",
			"request": "launch",
			"name": "Debug Current TS File",
			"runtimeArgs": [
				"-r",
				"ts-node/register"
			],
			"args": [
				"${file}"
			],
			"cwd": "${workspaceFolder}",
			"internalConsoleOptions": "openOnSessionStart",
			"skipFiles": [
				"<node_internals>/**"
			]
		},
		{
			"type": "node",
			"request": "launch",
			"name": "Debug Current TS File (npx)",
			"runtimeExecutable": "npx",
			"runtimeArgs": [
				"ts-node"
			],
			"args": [
				"${file}"
			],
			"cwd": "${workspaceFolder}",
			"internalConsoleOptions": "openOnSessionStart",
			"skipFiles": [
				"<node_internals>/**"
			]
		},
		{
			"type": "node",
			"request": "launch",
			"name": "Debug Current TS File (tsx)",
			"runtimeExecutable": "tsx",
			"args": [
				"${file}"
			],
			"cwd": "${workspaceFolder}",
			"internalConsoleOptions": "openOnSessionStart",
			"skipFiles": [
				"<node_internals>/**"
			]
		}
	],
	"inputs": [
		{
			"id": "handlerName",
			"type": "pickString",
			"description": "handler to run",
			"default": "basic-websock",
			"options": [
				"basic-websock",
				"other-websock"
			]
		},
		{
            "id": "awsProfileName",
            "type": "promptString",
            "description": "AWS SSO profile name"
        }
	]
}